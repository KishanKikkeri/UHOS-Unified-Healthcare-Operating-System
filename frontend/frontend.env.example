# UHOS Frontend — Environment Variables
# Copy to .env.local for local dev, or set in Vercel project settings for
# production. No secrets — this is just the API location.

# Base URL of the deployed backend (FastAPI). The dashboard WebSocket
# derives its URL from this (http -> ws, https -> wss), so no separate
# WS env var is needed — see frontend/lib/ws.ts.
NEXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app

# Phase 12 — Demo Mode. When "true", the landing page shows one-click
# role cards instead of a Login button, and /login itself adds a role
# picker above the username/password form. Independent of the backend's
# own DEMO_MODE flag — both must be "true" for demo login to actually
# succeed (this one only controls what the UI *offers*; the backend's
# flag is what the /auth/demo-login endpoint actually checks).
NEXT_PUBLIC_DEMO_MODE=false
