# UHOS Backend — Environment Variables
# Copy to .env for local use, or set these directly in your host
# (Railway / Render / Fly.io) dashboard. No secrets are committed here.

# --- Database ---
# Defaults to a local SQLite file if unset (zero-setup local dev).
# For production, set to a Postgres connection string, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/uhos
DATABASE_URL=sqlite:///./uhos.db

# --- Server ---
# Most PaaS providers (Railway/Render) inject PORT automatically; only
# set this manually for local/manual runs.
PORT=8000

# --- CORS ---
# Comma-separated list of allowed frontend origins in production.
# Current app.py allows "*" for demo simplicity — tighten this before
# a real deployment by reading this var in main.py's CORSMiddleware.
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# --- Phase 11: Authentication ---
# MUST be set to a long random value in any real deployment. Falls back to
# a fixed dev value locally so `uvicorn app.main:app` still works with zero
# setup, same pattern as DATABASE_URL above.
JWT_SECRET_KEY=uhos-dev-secret-change-me-in-production
# Access token lifetime, in minutes. Default: 480 (one 8-hour shift).
ACCESS_TOKEN_EXPIRE_MINUTES=480
